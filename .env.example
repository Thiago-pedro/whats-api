PORT=3000
API_KEY=troque-por-uma-chave-forte
CORS_ORIGIN=*

# ==========================================================
# MODO OFICIAL (index.js) - usado por npm start / Render
# ==========================================================
# URL do endpoint que recebe POST JSON (nao use a home do site SPA).
# Preferencia: INSTANZIA_*  |  Legado: LOVABLE_* (ainda aceito se INSTANZIA estiver vazio)
# INSTANZIA_EVENTS_URL=https://seu-dominio.com/api/.../whatsapp-events
# INSTANZIA_WEBHOOK_SECRET=troque-por-um-segredo-compartilhado

# Limite do body JSON (ex.: base64 de midia no POST /send)
# JSON_BODY_LIMIT=32mb

# Tamanho maximo de arquivo (bytes) para base64 ou download por URL
# MEDIA_MAX_BYTES=26214400

# Hosts permitidos para campo "url" no /send de midia (HTTPS), separados por virgula ou espaco.
# Sem isso, so arquivoBase64 / data URI — download por URL fica desabilitado.
# MEDIA_FETCH_ALLOWED_HOSTS=storage.supabase.co,seudominio.com

# Baileys: por padrao o index.js NAO baixa historico completo (evita timeout no Render).
# WHATSAPP_SYNC_HISTORY=1

# WEBHOOK_DEBUG=1

# ==========================================================
# MODO ALTERNATIVO (api.js + worker.js)
# ==========================================================
# REDIS_URL=redis://localhost:6379
# QUEUE_NAME=whatsapp-jobs
# AUTH_BASE_PATH=./auth
# WORKER_ID=worker-1
# MAX_SESSIONS_PER_TENANT=20
# DATABASE_URL=postgres://user:password@localhost:5432/whatsapp_api
