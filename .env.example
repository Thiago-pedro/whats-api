PORT=3000
API_KEY=troque-por-uma-chave-forte
CORS_ORIGIN=*

# ==========================================================
# MODO OFICIAL (index.js) - usado por npm start / Render
# ==========================================================
# Opcional: URL completa do endpoint que recebe POST JSON (não use só a home do site — rotas SPA devolvem 200 + HTML e o webhook “parece” ok).
# Ex. Lovable/Supabase: …/functions/v1/whatsapp-events
# Ex. Instanzia: confirme no código do app a URL exata da API (pode ser outro host ou path que não seja o bundle React).
# LOVABLE_EVENTS_URL=https://www.instanzia.com.br/api/public/v1/whatsapp-events
# LOVABLE_WEBHOOK_SECRET=troque-por-um-segredo-compartilhado

# Baileys: por padrão o index.js NÃO baixa histórico completo (evita "timed out waiting for message" no Render).
# Só ative se precisar de messaging-history.set e tiver RAM de sobra:
# WHATSAPP_SYNC_HISTORY=1

# Ruído: defina WEBHOOK_DEBUG=1 no Render para logar cada POST de webhook (URL + body) ao depurar.
# WEBHOOK_DEBUG=1

# ==========================================================
# MODO ALTERNATIVO (api.js + worker.js)
# ==========================================================
# REDIS_URL=redis://localhost:6379
# QUEUE_NAME=whatsapp-jobs
# AUTH_BASE_PATH=./auth
# WORKER_ID=worker-1
# MAX_SESSIONS_PER_TENANT=20
# DATABASE_URL=postgres://user:password@localhost:5432/whatsapp_api
